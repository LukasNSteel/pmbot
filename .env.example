# Only required for LIVE trading. Paper mode needs nothing here.
#
# Private key controlling your Polymarket funds:
#  - Email/Magic login: Polymarket → Settings → Export Private Key
#  - Browser wallet login: your wallet's private key
POLYMARKET_PRIVATE_KEY=

# Your Polymarket deposit address (the address shown in your Polymarket profile,
# which holds the USDC). Leave empty if trading from a plain EOA wallet.
POLYMARKET_FUNDER=

# Builder API-key credentials (signature_type 3 / deposit wallets only).
# Required ONLY for gasless on-chain merging of YES+NO pairs back to pUSD.
# Get them from the Builders page on polymarket.com (apiKey / secret /
# passphrase). This is NOT the standalone "Relayer API key" (key + address
# only). Leave empty to skip merging (pairs still redeem at resolution;
# capital is just locked meanwhile).
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=
